# Run outputs — never commit these (they're per-run artifacts)
results/
*.log
*.stderr

# ...except per-testcase reference answers, which are intentional content.
!tests/**/golden.log

# Submission logs inside official_testcase/ are intentional content.
!official_testcase/**/*.log

# Pyverilog parser cache (regenerated on first import)
parser.out
parsetab.py

# ABC subprocess artifacts
*.history
abc.history

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.Python

# Virtual environments
.venv/
venv/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*~

# Local LLM config (might contain API keys — see ../cada0001_alpha/llm_config.example.yaml)
llm_config.yaml

# Anything that ends in .env (defensive — no secret should ever be in repo)
*.env
.env*
